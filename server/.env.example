# ============================================================================
#  STACKPILOT — BACKEND ENV (Render / local)
#  Copy to server/.env and fill the values. NEVER commit the filled file.
# ============================================================================

# ── REQUIRED: core server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Your deployed frontend URL(s), comma-separated. Defaults to localhost in dev.
CORS_ORIGIN=https://your-frontend.vercel.app

# ── REQUIRED: auth + encryption ─────────────────────────────────────────────
# Random 48+ char string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_HMAC_SECRET=replace_with_a_long_random_secret_at_least_48_chars
TOKEN_EXPIRES_DAYS=7
# base64 of 32 random bytes. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=replace_with_base64_32_byte_key

# ── REQUIRED: agent wallet (Stacks) ─────────────────────────────────────────
STACKS_NETWORK=testnet
HIRO_API=https://api.testnet.hiro.so
PROTOCOL_ID=bitflow-amm
# Deployed agent-policy contract id: ST<deployer>.agent-policy
STACKS_CONTRACT=
# The agent's own Stacks private key (hex) so the server signs as that agent.
# Omit to generate a fresh server-controlled agent wallet per owner.
AGENT_IMPORT_KEY=
# Optionally pre-bind an existing policy id on boot (else create one live in the UI).
AGENT_IMPORT_POLICY_ID=

# ── RECOMMENDED ─────────────────────────────────────────────────────────────
# Real Gemini key for richer NL parsing. Without it, a deterministic regex
# fallback is used (the demo still works).
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
# Auto-DCA safety cap (max recurring runs).
DCA_MAX_RUNS=24

# ── OPTIONAL: persistence ───────────────────────────────────────────────────
# Without these the server runs in no-database mode: stateless HMAC auth +
# in-memory agent store (resets on restart). Set both to persist across restarts.
# SUPABASE_URL=
# SUPABASE_KEY=

# ── LOCAL DEV ONLY — DO NOT set in production ───────────────────────────────
# Auth bypass for local testing (trusts an x-dev-wallet header). Never in prod.
# AGENT_DEV_AUTH=true
