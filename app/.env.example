# ============================================================================
#  STACKPILOT — FRONTEND ENV (Vite / Vercel)
#  In Vercel: Project Settings → Environment Variables. All must be prefixed VITE_.
#  Only VITE_* vars are exposed to the browser. NEVER put secrets here.
# ============================================================================

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Backend API base URL. Point at your hosted backend (e.g. Render). Without a
# backend the landing + UI still render; agent actions fail gracefully.
VITE_API_BASE_URL=https://your-backend.onrender.com

# Stacks network the app targets.
VITE_STACKS_NETWORK=testnet
VITE_HIRO_API=https://api.testnet.hiro.so

VITE_MAINTENANCE_MODE=false

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Onboarding/email flow (off by default — a connected Stacks wallet is the account).
VITE_ENABLE_ONBOARDING=false

# ── LOCAL DEV ONLY — DO NOT set in a public production deploy ────────────────
# Sends the connected address as x-dev-wallet so the backend dev-auth accepts it.
# Only enable when the backend also runs AGENT_DEV_AUTH=true.
# VITE_AGENT_DEV_AUTH=true
